<h1 class="mb-3"><%= @place["name"] %></h1>

<h2 class="mb-3">My Entries</h2>

<div class="row">
  <% for entry in @entries %>
    <div class="col-md-4 mb-4">
      <div class="card h-100">
        <div class="card-body">
          <h3 class="card-title h5"><%= entry["title"] %></h3>
          <h4 class="card-subtitle mb-2 text-muted h6"><%= entry["occurred_on"] %></h4>
          <p class="card-text"><%= entry["description"] %></p>
<% if entry["image"] != nil %>
  <img src="/uploads/<%= entry["image"] %>" class="img-fluid mt-2">
<% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>

<% if logged_in? %>
  <p>
    <a href="/places/<%= @place["id"] %>/entries/new" class="btn btn-primary">New Entry</a>
  </p>
<% end %>

<p>
  <a href="/places" class="btn btn-secondary">Back to All Places</a>
</p>